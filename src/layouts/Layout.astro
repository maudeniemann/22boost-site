---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '22Boost — Clean Energy. No Toxicity.',
  description = '22Boost is a single-serve energy powder built for people who demand clean energy. Powered by yerba mate, L-theanine, and rhodiola rosea.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://22boost.com" />

    <!-- Preload Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon (22 logo) -->
    <link rel="icon" type="image/svg+xml" href="/images/22-logo.svg" />
  </head>
  <body>
    <!-- Content -->
    <slot />

    <script>
      import '../scripts/timeline';
      import '../scripts/waitlist';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
