---
---

<div class="waitlist-bar">
  <form id="waitlist-form" class="waitlist-form">
    <input
      type="email"
      name="email"
      id="waitlist-email"
      placeholder="Email address"
      required
      autocomplete="email"
      class="waitlist-input"
    />
    <button type="submit" id="waitlist-btn" class="waitlist-btn">Join the Waitlist</button>
  </form>
  <span id="waitlist-msg" class="waitlist-msg" aria-live="polite"></span>
</div>
